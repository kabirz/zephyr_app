/*
 * Gateway board overlay for nrf24_f103rct6 — 基线 (手柄板, 无网络)
 *
 * 默认编译即此配置 (CONFIG_GW_NETWORKING=n): 纯 nRF24 <-> CAN 桥。
 * nRF24 与 CAN 引脚与 mod_handler 完全一致, 电源由 main.c 的
 * gw_power_init() 使能 (canpower/rf24power/mainpower)。
 *
 * 网关板 (带 W5500) 配置由 snippet `gateway_eth` 注入:
 *   WITH_GATEWAY_ETH=1 west build -b nrf24_f103rct6 gateway --sysbuild
 */

/ {
	chosen {
		zephyr,canbus = &can1;
		zephyr,settings-partition = &cfg_partition;
	};

	zephyr,user {
		canpower-gpios = <&gpioc 7 GPIO_ACTIVE_HIGH>;
		mainpower-gpios = <&gpioa 8 GPIO_ACTIVE_HIGH>;   /* 系统主电源 (5V) */
		linksw-gpios = <&gpioa 10 GPIO_PULL_UP>;          /* 手柄板 link 按键 */
	};
};

/* ================================================================
 * SPI2: nRF24L01P (基线仅 nRF24, W5500 由 snippet 注入)
 * ================================================================ */
&spi2 {
	pinctrl-0 = <&spi2_sck_master_pb13
		     &spi2_miso_master_pb14
		     &spi2_mosi_master_pb15>;
	pinctrl-names = "default";
	cs-gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;    /* nRF24 CS */
	status = "okay";

	nrf24: nrf24l01p@0 {
		compatible = "nordic,nrf24l01p";
		reg = <0x0>;
		spi-max-frequency = <8000000>;
		ce-gpios = <&gpioa 9 GPIO_ACTIVE_HIGH>;
		irq-gpios = <&gpioc 6 GPIO_ACTIVE_LOW>;
		power-gpios = <&gpioc 9 GPIO_ACTIVE_HIGH>;   /* 模块电源 (驱动管理 + POR 延时) */
		channel = <76>;
		data-rate = "1m";
		tx-power = "0dbm";
	};
};

/* ================================================================
 * CAN1: 250Kbps
 * ================================================================ */
&can1 {
	pinctrl-0 = <&can_rx_pa11 &can_tx_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

/* ================================================================
 * RTC
 * ================================================================ */
&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x10000000>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};
